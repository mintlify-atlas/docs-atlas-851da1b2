  "keyFeatures": [
    "JWT authentication with access and refresh tokens",
    "Multiple token locations (headers, cookies, query, JSON)",
    "Token freshness tracking for sensitive operations",
    "Scope-based authorization with wildcard support",
    "CSRF protection for cookie-based auth",
    "Token revocation and blocklist support",
    "Implicit token refresh middleware",
    "FastAPI dependency injection integration",
    "Customizable callbacks and error handlers",
    "Extra features via authx-extra (Redis, metrics, profiling)"
  ],
